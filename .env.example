# ChronosFinance environment configuration
# Copy to .env and fill in your values

# PostgreSQL
POSTGRES_USER=chronos
POSTGRES_PASSWORD=chronos_secret
POSTGRES_DB=chronos
POSTGRES_PORT=5432

# App environment
APP_ENV=development
LOG_LEVEL=INFO

# FMP API key (required for data ingestion)
FMP_API_KEY=your_fmp_api_key_here

# CORS — comma-separated origins, or "*" for any
CORS_ALLOW_ORIGINS=*

# Ports (optional, defaults shown)
API_PORT=8000
WEB_PORT=3000
AI_PORT=8100

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI-compatible (set base URL for local/alternative providers)
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
