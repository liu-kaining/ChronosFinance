# ChronosFinance environment configuration
# Copy to .env and fill in your values

# PostgreSQL
POSTGRES_USER=chronos
POSTGRES_PASSWORD=chronos_secret
POSTGRES_DB=chronos
POSTGRES_PORT=5432

# App environment
APP_ENV=development
LOG_LEVEL=INFO

# FMP API key (required for data ingestion)
FMP_API_KEY=your_fmp_api_key_here

# CORS — comma-separated origins, or "*" for any
CORS_ALLOW_ORIGINS=*

# Ports (optional, defaults shown)
API_PORT=8000
API_WRITE_PORT=8001
WEB_PORT=3000
AI_PORT=8100

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible (set base URL for local/alternative providers)
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Cloudflare R2 Storage (S3-compatible, for SEC filings cold storage)
# Required for cold-hot separation architecture
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=chronos-sec-filings
R2_REGION=auto
